# Database
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Redis
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# Server
PORT=8080
NODE_ENV=development

# Auth (Keycloak OIDC)
KEYCLOAK_CLIENT_ID=siteguardian
KEYCLOAK_CLIENT_SECRET=change-me
KEYCLOAK_ISSUER=https://auth.athide.nl/realms/siteguardian
NEXTAUTH_URL=http://localhost:8080
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32-minimum-32-chars

# Mistral (bestuurders-samenvatting, optioneel)
MISTRAL_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub (repo access)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email reports (optional)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SCAN_EMAIL_FROM=scan@publicvibes.nl

# Docker Compose production
PUBLIC_DOMAIN=guardian.publicvibes.nl
DB_PASSWORD=change-me
