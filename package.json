{
  "name": "site-guardian",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 8080",
    "build": "next build",
    "start": "next start -p 8080",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "test:e2e": "npx playwright test"
  },
  "dependencies": {
    "next": "15.3.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "3.24.3",
    "nodemailer": "6.9.16",
    "@prisma/client": "6.5.0",
    "@octokit/rest": "21.1.1",
    "playwright": "1.50.1"
  },
  "devDependencies": {
    "typescript": "5.7.3",
    "@types/node": "22.13.10",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "@types/nodemailer": "6.4.17",
    "@biomejs/biome": "1.9.4",
    "vitest": "3.0.9",
    "@vitest/coverage-v8": "3.0.9",
    "prisma": "6.5.0",
    "@playwright/test": "1.50.1"
  }
}
